generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  createdAt   DateTime     @default(now())
  comparisons Comparison[]
}

model Comparison {
  id             String          @id @default(cuid())

  prompt         String
  language       String

  createdAt      DateTime        @default(now())

  userId         String

  gptScore       Int?
  geminiScore    Int?
  claudeScore    Int?

  winner         String?

  reason         String?
  recommendation String?

  user           User            @relation(fields: [userId], references: [id])

  responses      ModelResponse[]
}

model ModelResponse {
  id           String     @id @default(cuid())
  provider     String
  model        String
  output       String
  duration     Int?
  tokens       Int?
  comparisonId String
  comparison   Comparison @relation(fields: [comparisonId], references: [id])
}
